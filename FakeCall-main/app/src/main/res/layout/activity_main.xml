<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    >

    <!-- Title -->
    <TextView
        android:id="@+id/Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FakeCall"
        android:textAlignment="center"
        android:textSize="66sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simple Fake call log maker"
        android:textAlignment="center"
        android:padding="8dp"/>

    <!-- Phone Number Input -->
    <EditText
        android:id="@+id/phonenumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Phone Number"
        android:inputType="phone"
        android:textSize="30dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp"
        android:padding="8dp"/>

    <!-- Call Type -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/spinnerTextview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call Type : "
            android:textSize="18sp"/>

        <Spinner
            android:id="@+id/calltype"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:spinnerMode="dropdown"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- Time Ago -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/timeagoTextview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time Ago (mins) : "
            android:textSize="18sp"/>

        <EditText
            android:id="@+id/timeago"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="1"
            android:inputType="number"
            android:text="1"
            android:layout_marginStart="16dp"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Duration -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/durationTextview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Duration (mins)   : "
            android:textSize="18sp"/>

        <EditText
            android:id="@+id/duration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="1"
            android:inputType="number"
            android:text="1"
            android:layout_marginStart="16dp"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Add Calllog Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/addlog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Calllog"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#000000"
        android:layout_marginTop="24dp"
        android:padding="25dp"/>

    <!-- github link -->
    <TextView
        android:id="@+id/githubProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Visit Github Profile"
        android:padding="20dp"
        android:textAlignment="center"
        android:textColor="#000000"></TextView>
</LinearLayout>